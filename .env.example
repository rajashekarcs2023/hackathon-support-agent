# Which tenant config to load (required)
TENANT_CONFIG=tenants/test_tenant.yaml

# Secrets (required)
OPENAI_API_KEY=your_api_key_here
AGENT_SEED_PHRASE=your_agent_seed_phrase_here
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Discord bot — reads FAQ channel messages (required)
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_FAQ_CHANNEL_ID=your_faq_channel_id_here

# Google Doc — live hacker guide (optional, leave blank to skip)
GOOGLE_DOC_ID=your_google_doc_id_here

# Optional
# LOG_LEVEL=ERROR             # ERROR (default), WARNING, INFO, or DEBUG
